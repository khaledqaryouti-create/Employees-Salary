// ─── OVERTIME TYPE LOOKUP ─────────────────────────────────────────────────────

model OvertimeType {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  nameAr         String?
  description    String?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // ── Hours & Amount Limits ──
  maxHoursDaily              Float?
  maxHoursWeekly             Float?
  maxHoursMonthly            Float?
  maxAmountDaily             Float?
  maxAmountWeekly            Float?
  maxAmountMonthly           Float?
  maxAmountPercentSalary     Float?
  upperLimitAction           String?

  // ── Budget ──
  budgetLimitEnabled         Boolean  @default(false)
  budgetHierarchy            String?

  // ── Work Week & Calendar ──
  workWeekStart              String?
  workWeekEnd                String?
  workingDaysPerMonth        Int?
  excludeWeekendsFromCalendar Boolean @default(false)
  shiftBasedWorkingDays      Boolean  @default(false)
  workingHoursPerDay         Float?

  // ── Rounding & Entry ──
  roundingRule               String?
  payWithRounding            Boolean  @default(false)
  entryFormat                String?
  autoCalcEnabled            Boolean  @default(false)

  // ── Rate & Calculation ──
  baseSalaryMultiplier       Float?
  fixedRateEnabled           Boolean  @default(false)
  fixedRateAmount            Float?
  includeHousing             Boolean  @default(false)
  conversionEnabled          Boolean  @default(false)
  conversionHoursPerDay      Float?

  // ── Validation & Overlap ──
  otSourceType               String?
  validateLimitsAt           String?
  checkOverlap               Boolean  @default(true)
  backDateLimitDays          Int?
  allowMultiplePerDay        Boolean  @default(true)

  // ── Shift & Schedule ──
  shiftEndDelayMinutes       Int?
  restrictToShift            Boolean  @default(false)
  restrictToShiftPeriod      Boolean  @default(false)
  requestDaysRestriction     String?

  // ── Attachments, Reason & ESS ──
  attachmentMandatory        Boolean  @default(false)
  reasonMandatory            Boolean  @default(false)
  essRestricted              Boolean  @default(false)
  nonPayrollRouting          Boolean  @default(false)
  nonPayrollCode             String?

  // ── Salary Calculation ──
  includeInSalaryCalc        Boolean  @default(true)
  salaryCalcMethod           String?
  includeBasicSalary         Boolean  @default(true)
  salaryCalcNote             String?

  @@unique([organizationId, name])
  @@index([organizationId])
}

