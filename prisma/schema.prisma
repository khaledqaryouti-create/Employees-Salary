generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}
// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  TENANT_ADMIN
  HR_ADMIN
  MANAGER
  EMPLOYEE
}

enum EmploymentType {
  LOCAL
  EXPATRIATE
  CONTRACT
  PART_TIME
}

enum PayrollRuleType {
  EARNING
  DEDUCTION
  EMPLOYER_COST
}

enum PayrollRunStatus {
  DRAFT
  PROCESSING
  PENDING_APPROVAL
  APPROVED
  PAID
  FAILED
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum SalaryComponentType {
  EARNING
  DEDUCTION
}

enum FormulaVariableSource {
  EMPLOYEE_FIELD
  CONFIG_VALUE
  COMPUTED
}

enum NotificationType {
  PAYSLIP_READY
  PAYROLL_RUN_STARTED
  PAYROLL_APPROVED
  LEAVE_APPROVED
  LEAVE_REJECTED
  COMPLIANCE_DEADLINE
}

// ─── ORGANIZATION (TENANT) ────────────────────────────────────────────────────

model Organization {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  displayName   String?
  contactEmail  String?
  website       String?
  address       String?
  dateFormat    String   @default("DD/MM/YYYY")
  country       String?
  currency      String   @default("USD")
  timezone      String   @default("UTC")
  payFrequency  String   @default("MONTHLY")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  branding          TenantBranding?
  employees         Employee[]
  payrollRuns       PayrollRun[]
  ruleSets          CountryRuleSet[]
  configValues      ConfigValue[]
  taxBrackets       TaxBracket[]
  salaryComponents  SalaryComponent[]
  customFields      CustomField[]
  leaveTypes        LeaveType[]
  approvalWorkflows ApprovalWorkflow[]
  users             Profile[]
  notifications     Notification[]
  auditLogs         RuleAuditLog[]
  aiAuditLogs       AiAuditLog[]
  glAccountMappings GlAccountMapping[]
  orgUnitLevels     OrgUnitLevel[]
  orgUnits          OrgUnit[]
  systemLogs        SystemLog[]
  jobFamilies       JobFamily[]
  jobTitles         JobTitle[]
  nationalities     Nationality[]
  religions         Religion[]
  attachmentTypes   AttachmentType[]
  contactTypes      ContactType[]
  healthStatuses    HealthStatus[]
  birthPlaces       BirthPlace[]
  assetTypes        AssetType[]
  universities      University[]
  faculties         Faculty[]
  academicDegrees           AcademicDegree[]
  competencyClassifications CompetencyClassification[]
  competencies              Competency[]
  trainingTypes             TrainingType[]
  certificateTypes          CertificateType[]
  deductionTypes            DeductionType[]
  otherIncomeTypes          OtherIncomeType[]
  overtimeTypes             OvertimeType[]
  branches                  Branch[]
  userGroups                UserGroup[]
  salaryTransactions        SalaryTransaction[]
  allowanceTypes            AllowanceType[]

  @@index([slug])
  @@index([isActive])
}

// ─── BRANCH ───────────────────────────────────────────────────────────────────

model Branch {
  id                     String       @id @default(cuid())
  organizationId         String
  organization           Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Basic identification
  name                   String
  nameAr                 String?
  code                   String?
  description            String?
  nationalCode           String?
  molId                  String?
  crId                   String?

  // Location & contact
  country                String?
  city                   String?
  address                String?
  poBox                  String?
  telephone              String?
  fax                    String?
  email                  String?
  website                String?
  socialSecurityLocation String?
  logoUrl                String?

  // Management
  managerName            String?
  establishedDate        DateTime?
  costCenter             String?

  // Financial & tax
  baseCurrency           String?
  taxCurrency            String?
  taxProfile             String?
  countryProfile         String?

  // Behaviour flags
  isHeadQuarter          Boolean      @default(false)
  deductNationalTax      Boolean      @default(false)
  syncFromHeadQuarter    Boolean      @default(false)
  canModifyEmployeeTax   Boolean      @default(false)
  isActive               Boolean      @default(true)

  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  orgUnits               OrgUnit[]
  profiles               Profile[]
  payrollRuns            PayrollRun[]

  @@unique([organizationId, code])
  @@index([organizationId])
}

// ─── USER GROUPS & PERMISSIONS ────────────────────────────────────────────────

model UserGroup {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  permissions    UserGroupPermission[]
  members        ProfileUserGroup[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model UserGroupPermission {
  id         String    @id @default(cuid())
  groupId    String
  group      UserGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  pageKey    String
  canView    Boolean   @default(false)
  canCreate  Boolean   @default(false)
  canEdit    Boolean   @default(false)
  canDelete  Boolean   @default(false)
  canApprove Boolean   @default(false)

  @@unique([groupId, pageKey])
  @@index([groupId])
}

model ProfileUserGroup {
  profileId  String
  profile    Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  groupId    String
  group      UserGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  assignedAt DateTime  @default(now())

  @@id([profileId, groupId])
  @@index([groupId])
}

// ─── TENANT BRANDING ──────────────────────────────────────────────────────────

model TenantBranding {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  logoUrl        String?
  primaryColor   String       @default("#2563eb")
  accentColor    String       @default("#7c3aed")
  companyNameOnSlip String?
  payslipFooter  String?
  updatedAt      DateTime     @updatedAt
}

// ─── USERS & AUTH ─────────────────────────────────────────────────────────────

model Profile {
  id             String       @id
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  branchId       String?
  branch         Branch?      @relation(fields: [branchId], references: [id])
  email          String       @unique
  fullName       String
  role           UserRole     @default(EMPLOYEE)
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  employee       Employee?
  aiConsent      Boolean      @default(false)
  aiConsentAt    DateTime?
  userGroups     ProfileUserGroup[]

  @@index([organizationId])
  @@index([organizationId, role])
  @@index([branchId])
}

// ─── EMPLOYEES ────────────────────────────────────────────────────────────────

model Employee {
  id               String         @id @default(cuid())
  organizationId   String
  organization     Organization   @relation(fields: [organizationId], references: [id])
  profileId        String?        @unique
  profile          Profile?       @relation(fields: [profileId], references: [id])
  employeeNumber   String   @unique
  fullName         String
  firstName        String?
  secondName       String?
  thirdName        String?
  lastName         String?
  email            String
  phone            String?
  nationality      String?
  country          String
  jobTitle         String?
  managerId        String?
  manager          Employee?      @relation("ManagerEmployee", fields: [managerId], references: [id])
  subordinates     Employee[]     @relation("ManagerEmployee")
  employmentType   EmploymentType @default(LOCAL)
  joinDate         DateTime
  terminationDate  DateTime?
  isActive         Boolean        @default(true)
  bankName         String?
  bankAccountEncrypted String?
  ibanEncrypted    String?
  nationalIdEncrypted  String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  orgUnitId         String?
  orgUnit           OrgUnit?       @relation(fields: [orgUnitId], references: [id])
  jobTitleId        String?
  jobTitleRef       JobTitle?      @relation(fields: [jobTitleId], references: [id])
  salaryStructure   SalaryStructure?
  payrollItems      PayrollItem[]
  leaveBalances     LeaveBalance[]
  leaveRequests     LeaveRequest[]
  payslips          Payslip[]
  customFieldValues    CustomFieldValue[]
  externalIds          EmployeeExternalId[]
  salaryTransactions   SalaryTransaction[]

  @@index([organizationId, employeeNumber])
  @@index([organizationId])
  @@index([organizationId, country])
  @@index([organizationId, isActive])
}

// ─── EMPLOYEE EXTERNAL IDs (for integrations) ─────────────────────────────────

model EmployeeExternalId {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  system     String   // e.g. "SAP", "GOV_PORTAL", "WPS", "ODOO", "ORACLE"
  externalId String
  label      String?  // optional human-readable label for this mapping
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([employeeId, system])
  @@index([system, externalId])
}

model SalaryStructure {
  id             String   @id @default(cuid())
  employeeId     String   @unique
  employee       Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  basicSalary    Float
  currency       String   @default("USD")
  components     SalaryComponentValue[]
  effectiveFrom  DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model SalaryComponentValue {
  id                String          @id @default(cuid())
  salaryStructureId String
  salaryStructure   SalaryStructure @relation(fields: [salaryStructureId], references: [id], onDelete: Cascade)
  componentId       String
  component         SalaryComponent @relation(fields: [componentId], references: [id])
  amount            Float
  isPercentage      Boolean         @default(false)

  @@index([salaryStructureId])
}

// ─── FORMULA ENGINE ───────────────────────────────────────────────────────────

model CountryRuleSet {
  id             String       @id @default(cuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  country        String
  name           String
  year           Int          @default(2026)
  isDefault      Boolean      @default(false)
  isActive       Boolean      @default(true)
  clonedFromId   String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  rules          PayrollRule[]

  @@index([organizationId, country])
  @@index([country, isDefault])
}

model PayrollRule {
  id                   String          @id @default(cuid())
  ruleSetId            String
  ruleSet              CountryRuleSet  @relation(fields: [ruleSetId], references: [id], onDelete: Cascade)
  name                 String
  description          String?
  type                 PayrollRuleType
  formula              String
  applicableTo         String          @default("ALL")
  isActive             Boolean         @default(true)
  order                Int             @default(0)
  showOnPayslip        Boolean         @default(true)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  auditLogs            RuleAuditLog[]

  @@index([ruleSetId, isActive])
  @@index([ruleSetId, order])
}

model FormulaVariable {
  id             String                @id @default(cuid())
  organizationId String?
  key            String
  label          String
  description    String?
  sourceType     FormulaVariableSource
  defaultValue   String?
  isSystem       Boolean               @default(false)
  createdAt      DateTime              @default(now())

  @@unique([organizationId, key])
  @@index([organizationId])
}

model ConfigValue {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  country        String
  key            String
  value          String
  label          String?
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, country, key])
  @@index([organizationId, country])
}

model TaxBracket {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  country        String
  year           Int
  fromAmount     Float
  toAmount       Float?
  rate           Float
  fixedAmount    Float        @default(0)
  label          String?
  order          Int          @default(0)

  @@index([organizationId, country, year])
}

model SalaryComponent {
  id             String              @id @default(cuid())
  organizationId String
  organization   Organization        @relation(fields: [organizationId], references: [id])
  name           String
  nameAr         String?
  nameIt         String?
  type           SalaryComponentType
  country        String?
  isRequired     Boolean             @default(false)
  isActive       Boolean             @default(true)
  order          Int                 @default(0)

  values         SalaryComponentValue[]

  @@index([organizationId, isActive])
}

model CustomField {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  fieldType      String       @default("TEXT")
  isRequired     Boolean      @default(false)
  options        String?
  order          Int          @default(0)

  values         CustomFieldValue[]

  @@index([organizationId])
}

model CustomFieldValue {
  id           String      @id @default(cuid())
  employeeId   String
  employee     Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  customFieldId String
  customField  CustomField @relation(fields: [customFieldId], references: [id])
  value        String?

  @@unique([employeeId, customFieldId])
}

// ─── PAYROLL ──────────────────────────────────────────────────────────────────

model PayrollRun {
  id             String           @id @default(cuid())
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id])
  branchId       String?
  branch         Branch?          @relation(fields: [branchId], references: [id])
  name           String?
  periodYear     Int
  periodMonth    Int
  country        String?
  status         PayrollRunStatus @default(DRAFT)
  processedAt    DateTime?
  approvedAt     DateTime?
  approvedById   String?
  inngestJobId   String?
  totalGross     Float            @default(0)
  totalNet       Float            @default(0)
  totalDeductions Float           @default(0)
  employeeCount  Int              @default(0)
  currency       String           @default("USD")
  notes          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  items          PayrollItem[]
  payslips       Payslip[]

  @@index([organizationId, status])
  @@index([organizationId, periodYear, periodMonth])
  @@index([branchId])
}

model PayrollItem {
  id             String     @id @default(cuid())
  payrollRunId   String
  payrollRun     PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employeeId     String
  employee       Employee   @relation(fields: [employeeId], references: [id])
  grossPay       Float
  netPay         Float
  totalDeductions Float
  totalEarnings  Float
  earningsJson   Json
  deductionsJson Json
  employerCostJson Json     @default("{}")
  hasError       Boolean    @default(false)
  errorMessage   String?
  createdAt      DateTime   @default(now())

  @@unique([payrollRunId, employeeId])
  @@index([payrollRunId])
  @@index([employeeId])
}

model Payslip {
  id             String     @id @default(cuid())
  payrollRunId   String
  payrollRun     PayrollRun @relation(fields: [payrollRunId], references: [id])
  employeeId     String
  employee       Employee   @relation(fields: [employeeId], references: [id])
  pdfUrl         String?
  generatedAt    DateTime   @default(now())
  emailSentAt    DateTime?

  @@unique([payrollRunId, employeeId])
  @@index([employeeId])
}

// ─── LEAVE & ATTENDANCE ───────────────────────────────────────────────────────

model LeaveType {
  id              String        @id @default(cuid())
  organizationId  String?
  organization    Organization? @relation(fields: [organizationId], references: [id])
  name            String
  nameAr          String?
  color           String?
  isPaid          Boolean       @default(true)
  defaultDays     Int           @default(0)
  maxDaysPerYear  Int?
  accrualRule     String?
  carryOverDays   Int           @default(0)
  isDefault       Boolean       @default(false)
  isActive        Boolean       @default(true)

  balances       LeaveBalance[]
  requests       LeaveRequest[]

  @@index([isActive])
}

model LeaveBalance {
  id           String    @id @default(cuid())
  employeeId   String
  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveTypeId  String
  leaveType    LeaveType @relation(fields: [leaveTypeId], references: [id])
  year         Int
  totalDays    Float
  usedDays     Float     @default(0)
  pendingDays  Float     @default(0)

  @@unique([employeeId, leaveTypeId, year])
  @@index([employeeId])
}

model LeaveRequest {
  id           String             @id @default(cuid())
  employeeId   String
  employee     Employee           @relation(fields: [employeeId], references: [id])
  leaveTypeId  String
  leaveType    LeaveType          @relation(fields: [leaveTypeId], references: [id])
  startDate    DateTime
  endDate      DateTime
  days         Float
  reason       String?
  status       LeaveRequestStatus @default(PENDING)
  approvedById String?
  approvedAt   DateTime?
  rejectionReason String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([employeeId, status])
}

// ─── APPROVAL WORKFLOWS ───────────────────────────────────────────────────────

model ApprovalWorkflow {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  type           String       @default("PAYROLL")
  levels         Int          @default(1)
  config         Json
  isActive       Boolean      @default(true)

  @@index([organizationId, type])
}

// ─── AUDIT & LOGS ─────────────────────────────────────────────────────────────

model RuleAuditLog {
  id             String      @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  ruleId         String?
  rule           PayrollRule? @relation(fields: [ruleId], references: [id])
  action         String
  oldFormula     String?
  newFormula     String?
  changedById    String
  changedByEmail String
  changedAt      DateTime    @default(now())

  @@index([organizationId, changedAt])
  @@index([ruleId])
}

model AiAuditLog {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  userId          String
  userRole        String
  page            String?
  dataCategories  String[]
  query           String
  wasAnswered     Boolean      @default(true)
  wasBlocked      Boolean      @default(false)
  createdAt       DateTime     @default(now())

  @@index([organizationId, createdAt])
  @@index([userId])
}

// ─── NOTIFICATIONS ────────────────────────────────────────────────────────────

model Notification {
  id             String           @id @default(cuid())
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id])
  userId         String
  type           NotificationType
  title          String
  message        String
  isRead         Boolean          @default(false)
  createdAt      DateTime         @default(now())

  @@index([organizationId, userId, isRead])
}

// ─── GL ACCOUNT MAPPING ───────────────────────────────────────────────────────

model GlAccountMapping {
  id               String       @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id])
  componentName    String
  debitAccount     String
  creditAccount    String
  description      String?

  @@unique([organizationId, componentName])
  @@index([organizationId])
}

// ─── COMPANY STRUCTURE ────────────────────────────────────────────────────────

model OrgUnitLevel {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String       // e.g. "Site", "Department", "Section", "Division"
  depth          Int          // 0 = top-level (Site), 1, 2, 3 …
  color          String?      // optional UI badge color
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  units          OrgUnit[]

  @@unique([organizationId, depth])
  @@unique([organizationId, name])
  @@index([organizationId])
}

model OrgUnit {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  levelId        String
  level          OrgUnitLevel @relation(fields: [levelId], references: [id])
  branchId       String?
  branch         Branch?      @relation(fields: [branchId], references: [id])
  name           String
  code           String?
  parentId       String?
  parent         OrgUnit?     @relation("OrgUnitParent", fields: [parentId], references: [id])
  children       OrgUnit[]    @relation("OrgUnitParent")
  isActive       Boolean      @default(true)
  order          Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  employees      Employee[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([parentId])
  @@index([levelId])
  @@index([branchId])
}

// ─── JOB FAMILY & JOB TITLE LOOKUPS ──────────────────────────────────────────

model JobFamily {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  nameAr         String?
  description    String?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  jobTitles      JobTitle[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model JobTitle {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  jobFamilyId    String
  jobFamily      JobFamily    @relation(fields: [jobFamilyId], references: [id])
  name           String
  nameAr         String?
  grade          String?
  mappingCode     String?
  integrationCode String?
  isActive        Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  employees      Employee[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([jobFamilyId])
}

// ─── NATIONALITY LOOKUP ───────────────────────────────────────────────────────

model Nationality {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  nameAr         String?
  code           String?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId])
}

// ─── RELIGION LOOKUP ──────────────────────────────────────────────────────────

model Religion {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  nameAr         String?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId])
}

// ─── ATTACHMENT TYPE LOOKUP ───────────────────────────────────────────────────

model AttachmentType {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  nameAr         String?
  description    String?
  isRequired     Boolean      @default(false)
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId])
}

// ─── CONTACT TYPE LOOKUP ──────────────────────────────────────────────────────

model ContactType {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  nameAr         String?
  description    String?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId])
}

// ─── HEALTH STATUS LOOKUP ─────────────────────────────────────────────────────

model HealthStatus {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  nameAr         String?
  description    String?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId])
}

// ─── BIRTH PLACE LOOKUP ───────────────────────────────────────────────────────

model BirthPlace {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  nameAr         String?
  description    String?
  isActive       Boolean      @default(true)
